{
  "buildCommand": "yarn install && yarn build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/api/questionnaires/(.*)/process",
      "destination": "/api/questionnaires/process?id=$1"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
